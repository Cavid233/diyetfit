{
  "extends": "@react-native/typescript-config",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": [
    ".vscode",
    "assets",
    "android",
    "ios",
    "node_modules",
    "patches",
    "react-native.config.js",
    "jest.config.js",
    "metro.config.js",
    "**/Pods"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/components": ["app/components"],
      "@/constants": ["app/constants"],
      "@/navigation": ["app/navigation"],
      "@/hooks": ["app/hooks"],
      "@/containers": ["app/containers"],
      "@/screens": ["app/screens"],
      "@/assets": ["app/assets"],
      "@/services": ["app/services"],
      "@/store": ["app/store"],
      "@/types": ["app/types"],
      "@/utils": ["app/utils"],
      "@/helpers": ["app/helpers"],
      "@/api": ["app/api"],
      "@/schemas": ["app/schemas"],
    },
    "lib": ["ESNext", "DOM"],
    "declaration": true,
    "sourceMap": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "isolatedModules": true
  }
}
